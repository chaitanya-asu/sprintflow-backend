# ============================================================================
# SprintFlow - Environment Variables Template
# ============================================================================
# 
# SECURITY: Never commit actual values to version control!
# This file shows required environment variables for production deployment.
#
# Usage:
# 1. Copy this file to .env (add .env to .gitignore)
# 2. Replace placeholder values with actual secrets
# 3. Load environment variables before starting application
#
# On Linux/Mac:
#   export $(cat .env | xargs)
#   java -jar sprintflow.jar
#
# On Windows:
#   set /p=<.env
#   java -jar sprintflow.jar
#
# On Docker:
#   docker run --env-file .env sprintflow
#
# On AWS EC2:
#   Add to /etc/environment or use AWS Systems Manager Parameter Store
# ============================================================================

# ── Database Configuration ──────────────────────────────────────────────────
# MySQL connection details
DB_URL=jdbc:mysql://localhost:3306/sprintflow_db?useSSL=true&serverTimezone=UTC
DB_USERNAME=sprintflow_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Hibernate DDL mode (MUST be 'validate' in production)
DDL_AUTO=validate

# ── JWT Security ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# MUST be at least 64 hex characters (256 bits)
APP_JWT_SECRET=CHANGE_ME_64_HEX_CHARS_HERE_EXAMPLE_4e6a4b3d2f1c0e9d8c7b6a5a4b3c2d1e0f9a8b7c6d5e4f3a2b1c0d9e8f7a6b5c

# JWT token expiration (milliseconds)
# Default: 86400000 (24 hours)
APP_JWT_EXPIRATION=86400000

# JWT refresh token expiration (milliseconds)
# Default: 604800000 (7 days)
APP_JWT_REFRESH_EXPIRATION=604800000

# ── Email Encryption ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
# MUST be exactly 32 hex characters (128 bits)
APP_MAIL_KEY=CHANGE_ME_32_HEX_CHARS_HERE_EXAMPLE_a1b2c3d4e5f67890a1b2c3d4e5f67890

# ── CORS Configuration ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Production: Use your actual frontend domain
APP_CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Frontend URL for email links
APP_FRONTEND_URL=https://your-domain.com

# ── Server Configuration ────────────────────────────────────────────────────
# Server port (default: 8080)
PORT=8080

# ── Swagger/OpenAPI ─────────────────────────────────────────────────────────
# Disable in production for security
SWAGGER_ENABLED=false

# ── Rate Limiting ───────────────────────────────────────────────────────────
# Enable/disable rate limiting
RATE_LIMIT_ENABLED=true

# Login rate limit (requests per minute)
RATE_LIMIT_LOGIN=5

# API rate limit (requests per minute per user)
RATE_LIMIT_API=100

# Public endpoint rate limit (requests per minute per IP)
RATE_LIMIT_PUBLIC=20

# ── Session Configuration ───────────────────────────────────────────────────
# Session timeout (seconds)
# Default: 1800 (30 minutes)
SESSION_TIMEOUT=1800

# ── File Upload ─────────────────────────────────────────────────────────────
# Maximum file upload size (bytes)
# Default: 10485760 (10 MB)
MAX_FILE_SIZE=10485760

# Maximum request size (bytes)
# Default: 10485760 (10 MB)
MAX_REQUEST_SIZE=10485760

# ── Logging ─────────────────────────────────────────────────────────────────
# Log level (TRACE, DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=/var/log/sprintflow/application.log

# ── AWS Configuration (if using AWS services) ───────────────────────────────
# AWS Region
AWS_REGION=us-east-1

# AWS Access Key (use IAM roles instead if possible)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# S3 Bucket for file storage
# AWS_S3_BUCKET=sprintflow-files

# ── Redis Configuration (if using Redis for caching) ────────────────────────
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# ── Monitoring & Observability ──────────────────────────────────────────────
# Enable Spring Boot Actuator endpoints
ACTUATOR_ENABLED=true

# Actuator endpoints to expose (comma-separated)
ACTUATOR_ENDPOINTS=health,metrics,info

# ── Backup Configuration ────────────────────────────────────────────────────
# Database backup schedule (cron expression)
# Default: 0 2 * * * (daily at 2 AM)
BACKUP_SCHEDULE=0 2 * * *

# Backup retention days
BACKUP_RETENTION_DAYS=30

# ── Security Headers ────────────────────────────────────────────────────────
# Content Security Policy
CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'

# ── Additional Security ─────────────────────────────────────────────────────
# Enable HTTPS redirect
HTTPS_REDIRECT=true

# Enable HSTS (HTTP Strict Transport Security)
HSTS_ENABLED=true

# HSTS max age (seconds)
HSTS_MAX_AGE=31536000

# ============================================================================
# VERIFICATION CHECKLIST
# ============================================================================
# 
# Before deploying to production, verify:
# 
# ✓ All CHANGE_ME values replaced with actual secrets
# ✓ JWT secret is at least 64 hex characters
# ✓ Mail encryption key is exactly 32 hex characters
# ✓ Database password is strong (12+ characters, mixed case, numbers, symbols)
# ✓ DDL_AUTO is set to 'validate' (never 'update' or 'create' in production)
# ✓ SWAGGER_ENABLED is set to 'false'
# ✓ CORS origins match your actual frontend domain
# ✓ Rate limiting is enabled
# ✓ HTTPS redirect is enabled
# ✓ Log level is set to INFO or WARN (not DEBUG)
# ✓ File upload limits are appropriate for your use case
# ✓ Backup schedule is configured
# ✓ .env file is added to .gitignore
# ✓ Environment variables are loaded before application starts
# 
# ============================================================================
