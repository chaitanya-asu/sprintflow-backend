# SprintFlow Backend Environment Variables
# Copy this to .env and fill in your actual values
# NEVER commit this file with real secrets!

# JWT Configuration (REQUIRED - must be 64 hex characters)
# Generate using: openssl rand -hex 32
# Or run: generate-jwt-secret.bat
# Or PowerShell: -join ((1..64) | ForEach {'{0:X}' -f (Get-Random -Max 16)})
APP_JWT_SECRET=REPLACE_WITH_YOUR_64_CHAR_HEX_SECRET

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/sprintflow_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Mail Encryption Key (32 hex characters)
# Generate using: openssl rand -hex 16
# Or PowerShell: -join ((1..32) | ForEach {'{0:X}' -f (Get-Random -Max 16)})
APP_MAIL_KEY=REPLACE_WITH_YOUR_32_CHAR_HEX_KEY

# Frontend URL
APP_FRONTEND_URL=http://localhost:5173

# CORS Origins
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Database DDL Mode (update for dev, validate for prod)
DDL_AUTO=update

# Swagger (true for dev, false for prod)
SWAGGER_ENABLED=true