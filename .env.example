# ─────────────────────────────────────────────────────────────
# SprintFlow — Production Environment Variables
#
# SETUP:
#   cp .env.example .env
#   nano .env          ← fill in every value
#   chmod 600 .env     ← restrict read access
#
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── MySQL ─────────────────────────────────────────────────────
# Root password (used by MySQL container internally)
MYSQL_ROOT_PASSWORD=ChangeThisRootPassword123!

# App database user (Spring Boot connects with these)
DB_USERNAME=sprintflow
DB_PASSWORD=ChangeThisDbPassword123!

# ── JWT Secret ────────────────────────────────────────────────
# REQUIRED — must be exactly 64 hex characters (256 bits)
# Generate: openssl rand -hex 32
APP_JWT_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32

# ── Mail Encryption Key ───────────────────────────────────────
# REQUIRED — must be exactly 32 hex characters (128 bits)
# Used to AES-encrypt manager SMTP passwords stored in the DB
# Generate: openssl rand -hex 16
APP_MAIL_KEY=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_16

# ── CORS & Frontend URL ───────────────────────────────────────
# Set to https://YOUR_SERVER_IP (the public IP of your server)
# This is what the browser uses to reach the app
APP_CORS_ORIGINS=https://YOUR_SERVER_IP
APP_FRONTEND_URL=https://YOUR_SERVER_IP

# ── Vite Build Args (baked into React bundle at build time) ───
# The browser calls these URLs directly
# Since Nginx proxies /api and /ws, use the same base URL
VITE_API_BASE_URL=https://YOUR_SERVER_IP/api
VITE_WS_URL=https://YOUR_SERVER_IP

# ── Frontend Path ─────────────────────────────────────────────
# Path to the frontend repository for Docker build
# Default: ../sprintflow-frontend (assumes repos are side by side)
FRONTEND_PATH=../sprintflow-frontend

# ── Swagger ───────────────────────────────────────────────────
# false = API docs hidden from public (recommended for production)
SWAGGER_ENABLED=false
